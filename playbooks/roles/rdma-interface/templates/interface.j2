{%- set rdma_subnet = hostvars[inventory_hostname]['rdma_network'] + '/' + hostvars[inventory_hostname]['rdma_netmask'] -%}
{%- set rdma_subnet_prefix = rdma_subnet | ansible.utils.ipaddr('prefix') -%}
{%- set rdma_subnet_cidr = rdma_subnet | ansible.utils.ipaddr('network/prefix') -%}
{%- set host_index = hostvars[inventory_hostname]['ansible_default_ipv4']['address'] | ansible.utils.ipsubnet(hostvars[inventory_hostname]['private_subnet'])  -%}
{# THIS WHOLE ROUTINE IS USED TO FIND THE NEXT SUBNET #}
{%- set subnets = [rdma_subnet_cidr] -%}
{%- for i in range(index) -%}
  {%- set nsip = subnets|last | ansible.utils.ipaddr('net') | ansible.utils.ipaddr('-1') | ansible.utils.ipmath(1) -%}
  {%- set ns = nsip + '/' + rdma_subnet_prefix|string -%}
  {{ subnets.append(ns) }}
{%- endfor -%}
{%- set rdma_address = subnets|last | ansible.utils.ipmath(host_index | int -1) -%}
auto {{ item['device'] }}
iface {{ item['device'] }} inet static
      address {{ rdma_address }}
      netmask {{ hostvars[inventory_hostname]['rdma_netmask'] }}

