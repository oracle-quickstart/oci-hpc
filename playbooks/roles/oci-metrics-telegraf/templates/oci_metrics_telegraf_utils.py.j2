from abc import ABC, abstractmethod
import logging

logger = logging.getLogger(__name__)


class OCIClientFactory:
    """Factory for creating OCI clients with proper configuration."""
    
    def __init__(self, config=None, signer= None, retry_strategy=None):
        self.config = config or {}
        self.signer = signer
        
        if retry_strategy:
            self.retry_strategy = retry_strategy
        else:
            from oci.retry import DEFAULT_RETRY_STRATEGY
            self.retry_strategy = DEFAULT_RETRY_STRATEGY
    
    def create_client(self, client_class):
        """Create a client with standardized configuration."""
        return client_class(
            config=self.config,
            signer=self.signer,
            retry_strategy=self.retry_strategy
        )


class ResourceHandler(ABC):
    """Abstract base class for handling specific resource types."""
    
    def __init__(self, factory):
        self.factory = factory
        self._clients = {}
    
    @abstractmethod
    def get_resource_identifier_key(self):
        """Return the key used to identify resources for this handler."""
        pass
    
    @abstractmethod
    def initialize_clients(self):
        """Initialize required OCI clients."""
        pass

    @abstractmethod
    def get_client(self, client_type):
        """Return the requested client for this handler type."""
        pass

    @abstractmethod
    def get_resource(self, resource_id, tags):
        """Retrieve resource and return (response, attribute_mapping)."""
        pass


class APIGatewayHandler(ResourceHandler):
    def get_resource_identifier_key(self):
        return "resourceId"
    
    def initialize_clients(self):
        if 'GatewayClient' not in self._clients:
            from oci.apigateway import GatewayClient
            self._clients['GatewayClient'] = self.factory.create_client(GatewayClient)

    def get_client(self, client_type):
        if client_type == 'GatewayClient':
            if client_type not in self._clients:
                self.initialize_clients()
            return self._clients[client_type]
        raise ValueError(f"Unsupported client type: {client_type}")
    
    def get_resource(self, resource_id, tags):
        if "apigateway" not in resource_id.split("."):
            raise ValueError(f"Unsupported resource ID for the APIGatewayHandler: {resource_id}")
        
        self.initialize_clients()
        response = self.get_client('GatewayClient').get_gateway(resource_id)
        return response, {"display_name": "display_name"}


