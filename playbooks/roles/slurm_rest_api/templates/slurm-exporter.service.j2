[Unit]
Description=Slurm Exporter
Wants=network-online.target
After=network-online.target

[Service]
User={{ slurm_user }}
Group={{ slurm_group }}
Type=simple
Environment="PYTHONPATH=/usr/local/lib/python{{ python_version }}/site-packages:/usr/local/lib64/python{{ python_version }}/site-packages"
ExecStart={{ python_executable }} /usr/local/bin/slurm-exporter.py

[Install]
WantedBy=multi-user.target