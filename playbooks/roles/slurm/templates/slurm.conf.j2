{%- for partition in queues %}
{%- set ns = namespace(nodesList=[], has_ondemand=0) %}
{%- for instance in partition.instance_types %}
    {%- if instance.permanent %}
        {{- ns.nodesList.append(instance.name) -}}
    {%- else %}
        {{- ns.nodesList.append(instance.hostname_convention ~ '-[1-' ~ instance.max_number_nodes ~ ']') -}}
        {%- set ns.has_ondemand = 1 -%}
    {%- endif %}
{%- endfor %}
{%- if partition.default %}
    {%- if ns.has_ondemand == 1 %}
PartitionName={{ partition.name }} Nodes={{ ns.nodesList | join(',') }} Default=YES ResumeTimeout=1200 SuspendTimeout=200 SuspendTime=300
    {%- else %}
PartitionName={{ partition.name }} Nodes={{ ns.nodesList | join(',') }} Default=YES
PartitionName={{ partition.name }}-healthcheck Nodes={{ ns.nodesList | join(',') }} Default=NO PriorityTier=0
    {%- endif %}
{%- else %}
    {%- if ns.has_ondemand == 1 %}
PartitionName={{ partition.name }} Nodes={{ ns.nodesList | join(',') }} Default=NO ResumeTimeout=1200 SuspendTimeout=200 SuspendTime=300
    {%- else %}
PartitionName={{ partition.name }} Nodes={{ ns.nodesList | join(',') }} Default=NO
PartitionName={{ partition.name }}-healthcheck Nodes={{ ns.nodesList | join(',') }} Default=NO PriorityTier=0
    {%- endif %}
{%- endif %}
{{ "\n" -}}
{%- endfor %}
