SlurmctldHost={{ controller_hostname }}
{% if groups['slurm_backup'] | length > 0 %}
SlurmctldHost={{ slurm_backup_hostname }}
{% endif %}
MpiDefault=none
ProctrackType=proctrack/cgroup
ReturnToService=1
SlurmctldPidFile=/run/slurmctld.pid
SlurmctldPort=6817
SlurmdPidFile=/run/slurmd.pid
SlurmdPort=6818
SlurmdSpoolDir=/var/spool/slurmd
SlurmUser=slurm
Prolog={{slurm_conf_path}}/prolog.d/*
Epilog={{slurm_conf_path}}/epilog.d/*
SchedulerParameters=nohold_on_prolog_fail
MessageTimeout=120
SlurmctldLogFile=/var/log/slurm/slurmctld.log
SlurmdLogFile=/var/log/slurm/slurmd.log
StateSaveLocation={{ slurm_nfs_path }}/spool_{{ cluster_name }}/slurm
SwitchType=switch/none
TaskPlugin=task/affinity,task/cgroup
JobContainerType=job_container/tmpfs
PrologFlags=alloc,contain,serial
InactiveLimit=0
KillWait=30
MinJobAge=300
SlurmctldTimeout=300
SlurmdTimeout=600
Waittime=0
GresTypes=gpu
SchedulerType=sched/backfill
SelectType=select/cons_tres
SelectTypeParameters=CR_Core_Memory
AccountingStorageHost={{ controller_hostname }}
{% if groups['slurm_backup'] | length > 0 %}
AccountingStorageBackupHost={{ slurm_backup_hostname }}
{% endif %}
AccountingStorageType=accounting_storage/slurmdbd
AccountingStoreFlags=job_comment
ClusterName=cluster
JobAcctGatherFrequency=30
JobAcctGatherType=jobacct_gather/linux
SlurmctldDebug=info
SlurmdDebug=info
EnforcePartLimits=NO
PropagateResourceLimitsExcept=MEMLOCK
CommunicationParameters=block_null_hash
TopologyPlugin=topology/tree
TopologyParam=SwitchAsNodeRank
TreeWidth=2048
SlurmctldParameters=enable_configless
SlurmdParameters=numa_node_as_socket
MaxNodeCount=10000
UnkillableStepTimeout=600
AuthAltTypes=auth/jwt
AuthAltParameters=jwt_key={{ slurm_jwt_key_path }}
{% if healthchecks|bool %}
HealthCheckProgram={{slurm_conf_path}}/prolog.d/healthchecks.sh
HealthCheckInterval=300
HealthCheckNodeState=IDLE,CYCLE
PreemptMode=CANCEL
PreemptType=preempt/partition_prio
PreemptExemptTime=-1
{% endif %}
{% if sacct_limits|bool %}
AccountingStorageTRES=gres/gpu
AccountingStorageEnforce=limits,associations,qos,safe
JobCompType=jobcomp/none
TrackWckey=no
{% endif %}
ResumeProgram=/etc/slurm/resume.sh
SuspendProgram=/etc/slurm/suspend.sh
ResumeRate=0
SuspendRate=0

