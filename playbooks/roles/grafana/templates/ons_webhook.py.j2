    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
    )

    # Load template before starting daemons
    load_template()

    start_daemons()

# Bind the webhook service to localhost only.
# Grafana sends alerts via http://localhost:5000, so external access
# is not required. Binding to 127.0.0.1 prevents network exposure
# even if VCN security rules are modified in the future.

    uvicorn.run(app, host="127.0.0.1", port=5000)
